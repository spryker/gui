{% set navigationIconsType = navigationIconsType is defined ? navigationIconsType : 'font-awesome' %} {# Available types: 'font-awesome', 'google-material'  #}

{%- macro leaf(node, depth=0, navigationIconsType) -%}
    {%- import _self as menu -%}

    {%- if node is defined %}
        {%- if menu_highlight is defined -%}
            {%- if menu_highlight == node.uri -%}
                <li class="side-nav-item active" data-qa="menu-item">
            {%- else -%}
                <li class="side-nav-item" data-qa="menu-item">
            {%- endif -%}
        {%- else -%}
            <li class="side-nav-item {{ node.is_active is defined and node.is_active ?  'active' : '' }}" data-qa="menu-item">
        {%- endif -%}
            <a class="side-nav-link" href="{{ node.uri }}"{% if node.shortcut is defined %} data-hotkey="{{ node.shortcut }}"{% endif %} data-qa="menu-item-link">
                {{ menu.getNodeIcon(node, navigationIconsType) }}
                <span class="menu-text" data-qa="menu-item-label">{{ node.label | trans }}</span>
            </a>
        </li>
    {% endif -%}
{%- endmacro -%}

{%- macro branch(node, depth=0, navigationIconsType) -%}
    {%- import _self as menu -%}

    {%- if node is defined %}
        <li class="side-nav-item {{ node.is_active is defined and node.is_active ? ' active' : '' }}" data-qa="menu-parent-item">
            <a class="side-nav-link {{ node.is_active is defined and node.is_active ? '' : 'collapsed' }}" href="#menu-node-{{ node.title | lower | replace({' ': '-'}) }}"
                data-qa="menu-parent-link"
                data-bs-toggle="collapse">
                {{ menu.getNodeIcon(node, navigationIconsType) }}

                <span class="menu-text nav-label" data-qa="menu-item-label">{{ node.label | trans }}</span>
                {% if navigationIconsType == 'google-material'  %}
                    <span class="side-menu__arrow material-symbols-outlined">keyboard_arrow_down</span>
                {% else %}
                    <span class="fa arrow"></span>
                {% endif %}
            </a>
            
            <div class="collapse {{ node.is_active is defined and node.is_active ? "show" : "" }}" id="menu-node-{{ node.title | lower | replace({' ': '-'}) }}">
                <ul class="sub-menu nav-second-level" data-qa="menu-submenu">
                    {{ menu.tree(node.children, navigationIconsType) }}
                </ul>
            </div>
        </li>
    {% endif -%}
{%- endmacro -%}

{%- macro tree(root, navigationIconsType) -%}
    {%- import _self as menu -%}

    {%- for child in root -%}
        {%- if child.children is defined and child.children is not empty -%}
            {{ menu.branch(child, 0, navigationIconsType) }}
        {%- else -%}
            {{ menu.leaf(child, 0, navigationIconsType) }}
        {%- endif -%}
    {%- endfor -%}
{%- endmacro -%}

{%- macro getNodeIcon(node, navigationIconsType) -%}
    {%- set defaultIcon = navigationIconsType == 'google-material' ? 'keyboard_double_arrow_right' : 'fa-angle-double-right' -%}

    {% if navigationIconsType == 'google-material' %}
        {%- if node.icon is defined and node.icon != '' -%}
            <i class="side-menu__icon material-symbols-outlined">{{ node.icon }}</i>
        {%- else -%}
            <i class="side-menu__arrow material-symbols-outlined">{{ defaultIcon }}</i>
        {%- endif -%}
    {% else %}
        {%- if node.icon is defined and node.icon != '' -%}
            <i class="fa {{ node.icon }}"></i>
        {%- else -%}
            <i class="fa {{ defaultIcon }}"></i>
        {%- endif -%}
    {% endif %}
{%- endmacro -%}

{%- import _self as menu -%}


<div class="sidenav-menu">
    
    {% include '@Gui/Partials/logo.twig' %}

    <button class="button-close-offcanvas">
        <i class="ti ti-x align-middle"></i>
    </button>

    <div class="scrollbar" data-simplebar>
        <ul class="side-nav js-navigation-menu" role="navigation" data-lang="menu-title" data-qa="navigation-menu" id="side-menu">
            <div class="d-none px-2 d-xl-block">
                <input type="search" class="menu-filter-input js-menu-filter-input form-control"
                name="search" placeholder="{{ 'Filter' | trans }}"
                autocomplete="off"
                data-qa="menu-filter-input">
            </div>
            {{ menu.tree(navigation.menu, navigationIconsType) }}
        </ul>
    </div>
</div>
