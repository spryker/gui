{% if breadcrumbs|length > 0 %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 py-2" data-qa="breadcrumb">
            {% for breadcrumbItem in breadcrumbs %}
                <li class="breadcrumb-item">
                    {% if breadcrumbItem.uri is not empty %}
                        <a class="{{ loop.last ? 'disabled' }}" tabindex="{{ loop.last ? '-1' }}" href="{{ breadcrumbItem.uri }}" title="{{ breadcrumbItem.title | trans }}">
                            {{ breadcrumbItem.label | trans }}
                        </a>
                    {% else %}
                        {{ breadcrumbItem.label | trans }}
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    </nav>
{% endif %}
